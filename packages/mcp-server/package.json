{
  "name": "@wire-dsl/mcp-server",
  "version": "0.1.1",
  "description": "MCP server for Wire DSL — documentation, validation and rendering",
  "type": "module",
  "bin": {
    "wire-dsl-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "node ../../scripts/embed-fonts.js",
    "build": "tsup src/index.ts src/server.ts --format esm --dts --no-splitting --target node20",
    "dev": "tsx watch src/index.ts",
    "dev:http": "tsx watch src/index.ts --http",
    "build:watch": "tsup src/index.ts --watch --format esm --target node20",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --http",
    "sync-docs": "node ../../scripts/sync-mcp-docs.js",
    "embed-fonts": "node ../../scripts/embed-fonts.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.15.0",
    "@resvg/resvg-wasm": "^2.6.2",
    "@wire-dsl/engine": "workspace:*",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.2.0",
    "tsup": "8.5.1",
    "tsx": "^4.19.4",
    "typescript": "5.9.3"
  },
  "keywords": [
    "wireframe",
    "dsl",
    "mcp",
    "model-context-protocol",
    "wire-dsl"
  ],
  "author": "WireDSL Contributors",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
